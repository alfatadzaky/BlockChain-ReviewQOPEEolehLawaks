# ============================================
# SELURUH KONFIGURASI SUDAH BENAR DAN BERJALAN BAIK
# ============================================

# ============================================
# Konfigurasi Server
# ============================================
PORT=3099

# ============================================
# Konfigurasi Etherscan API (Sepolia Testnet)
# ============================================
# Dapatkan API key gratis di: https://etherscan.io/myapikey
ETHERSCAN_API_KEY=

# ============================================
# Alamat Smart Contract
# ============================================
# Ganti dengan alamat smart contract rantai pasok obat Anda di Sepolia
CONTRACT_ADDRESS=

# ============================================
# Base URL Etherscan API untuk Sepolia
# ============================================
ETHERSCAN_BASE_URL=https://api-sepolia.etherscan.io/api

# ============================================
# Alamat Role untuk Smart Contract
# ============================================
# Alamat produsen (owner di smart contract)
PRODUSEN_ADDRESS=
# Alamat distributor
DISTRIBUTOR_ADDRESS=
# Alamat apotek
APOTEK_ADDRESS=
